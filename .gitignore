# Dotfuscator Recommend
DotfuscatorReports/

# Crashlytics generated file
crashlytics-build.properties

# Rider
.idea/
*.sln.iml

# Code coverage files
*.coverage
*.coveragexml
coverage*

# macOS
.DS_Store

# JetBrains Rider
.idea/
*.sln.iml

# RynorArch Output tests
samples/**/Generated/

*.env